# EasyWay AI Website Builder – Backend .env
# Copy this file to .env and fill in your values

# Google Gemini API key (required for website generation)
GEMINI_API_KEY=AIzaSyAnQ_01phc5Jo4jgLwgurA1MalygNPi3IA

# Backend server port
PORT=3001

# Where published sites are stored on disk
# Default: ./public/sites (served at /sites/slug/index.html)
SITES_DIR=./public/sites

# Public base URL for published site links
# Change to your production domain when deploying
BASE_URL=http://localhost:3001
